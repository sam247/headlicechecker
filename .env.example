# Scan provider (required for production scan results). Roboflow only.
# ROBOFLOW_API_KEY=your_roboflow_api_key   (from Roboflow; set in Vercel, never commit)
# Option A: Serverless Workflow (Deploy > Serverless Hosted API). Unique URL = workspace / workflow_id.
# If you get 400 "Could not parse workflow definition" or ValidationError, fix the workflow in Roboflow
# Workflow Editor (check block config, references, required fields, classList/empty lists).
# ROBOFLOW_WORKSPACE=head-lice-checker
# ROBOFLOW_WORKFLOW_ID=check
# Option B: Legacy Detect API – from Roboflow Deploy > Inference API. Use path only: project/version
# (e.g. find-head-lice-instant/1). NOT the workflow model_id (e.g. head-lice-checker/find-head-lice-instant-1).
# Model must be Published for Hosted Inference.
# ROBOFLOW_MODEL_ID=find-head-lice-instant/1
#
# Roboflow Legacy Detect API checklist:
# - ROBOFLOW_MODEL_ID = path only, format project/version (no workspace, no full modern ID).
# - In Roboflow: Deploy → Inference API; confirm version is Published for Hosted Inference.
# - Copy the path from that URL into ROBOFLOW_MODEL_ID in Vercel.
# - API key must have access to this project/version.
# - Request uses Content-Type: application/x-www-form-urlencoded with base64 image (already implemented).
# - "Service misconfiguration" → check model ID, Published for Hosted Inference, and API key access.
# - "Forbidden" → API key invalid/expired/wrong workspace, or no access to this project/version; re-copy key from Roboflow.

# Development-only scan fallback (ignored in production)
# ALLOW_SCAN_STUB=true

# Lead delivery
# LEAD_EMAIL_PROVIDER=resend
# LEAD_FROM_EMAIL=alerts@headlicechecker.com
# LEAD_FALLBACK_TO=ops@headlicechecker.com
# CLINIC_APPLY_TO=partners@headlicechecker.com
# CLINIC_ENQUIRY_TO=info@headlicechecker.com
# RESEND_API_KEY=re_...
# POSTMARK_SERVER_TOKEN=...

# Structured analytics table (Google Sheets append-only)
# ANALYTICS_SHEET_ID=your_google_sheet_id
# ANALYTICS_SHEET_TAB=analytics_events
# ANALYTICS_METRICS_SHEET_TAB=analytics_metrics
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\"

# School toolkit leads table (Google Sheets append-only)
# SCHOOL_LEADS_SHEET_ID=1W7g7EkQqlNhJYbnayKFcxv6in5KcOuiflcCwOdpMCEk
# SCHOOL_LEADS_SHEET_TAB=SchoolLeads
# SCHOOL_TOOLKIT_CONFIRMATION_FROM=alerts@headlicechecker.com
# SCHOOL_TOOLKIT_OPS_BCC=ops@headlicechecker.com

# Clinic pricing labels (used on /for-clinics/pricing; non-hardcoded values)
# CLINIC_PRICING_FEATURED_LABEL=Contact us
# CLINIC_PRICING_STANDARD_LABEL=Contact us

# Mapbox (server-side geocode for find-clinics; set in Vercel, do not commit token)
# MAPBOX_ACCESS_TOKEN=pk....

# Security and rate limiting
# NEXT_PUBLIC_SITE_URL=https://headlicechecker.com
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=20
